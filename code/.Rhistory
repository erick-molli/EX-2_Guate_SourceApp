# Calculate percentages
totaltree <- sum(treedata$value)
treedata$percentage <- round((treedata$value / totaltree) * 100, 2)
treemap(treedata,
index = c("group", "subgroup"),
vSize = "value",
type = "index",
fontsize.labels = c(12, 10),
labels = paste0(treedata$percentage, "%"))
