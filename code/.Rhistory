#CREATE TREEMAP
#Build data set
group <- c(rep("Source1", 3), rep("Source2", 3), rep("Source3", 3), rep("Source4", 3)) #Sources as groups
subgroup <- c("Baseline", "Control", "Intervention") #Arms as subgroups
value <- c(96.86, 80.28, 8.55, 4.30, 2.90, 3.05, 3.52, 3.48, 2.95, 19.59, 16.87, 16.35) #Input concentrations as values
treedata <- data.frame(group, subgroup, value) #Create the treemap data frame
#Create the plot
treemap(treedata,
index = c("group", "subgroup"),
vSize = "value",
type = "index",
title = "Proportion of PM2.5 attributable to each source",
fontsize.labels = c(12, 10),
fontsize.title = 16,
fontsize.legend = 12,
bg.labels = "transparent",
overlap.labels = 0.5)
